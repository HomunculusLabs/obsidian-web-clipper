#!/bin/bash
# AI Gatekeeper Pre-Push Hook
# Reviews code with Codex before allowing push

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🛡️  AI Gatekeeper Pre-Push Review"
echo "=================================="

# Check if codex is installed
if ! command -v codex &> /dev/null; then
    echo -e "${YELLOW}⚠️  Codex CLI not found. Skipping pre-push review.${NC}"
    echo "   Install: npm install -g @openai/codex"
    exit 0
fi

# Get the current branch and remote info
while read local_ref local_oid remote_ref remote_oid; do
    # Skip if pushing to main (always require PR for main)
    if [[ "$remote_ref" == *"main"* ]] || [[ "$remote_ref" == *"master"* ]]; then
        echo -e "${YELLOW}⚠️  Pushing to main/master branch detected.${NC}"
        echo "   AI Gatekeeper requires PR reviews for main."
        echo "   Create a branch and open a PR instead."
        exit 1
    fi
    
    # Determine base for review
    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
        # New branch, use origin/develop or origin/main as base
        if git rev-parse --verify origin/develop &> /dev/null; then
            BASE="origin/develop"
        elif git rev-parse --verify origin/main &> /dev/null; then
            BASE="origin/main"
        else
            BASE="origin/master"
        fi
    else
        # Existing branch, use remote state as base
        BASE="$remote_oid"
    fi
    
    # Get current branch name
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    
    echo ""
    echo "Branch: $BRANCH"
    echo "Base: $BASE"
    echo ""
    
    # Run Codex review
    echo "🤖 Running AI code review..."
    echo "   (This may take 30-60 seconds)"
    echo ""
    
    REVIEW_OUTPUT=$(codex review --base "$BASE" --title "Pre-push review: $BRANCH" 2>&1)
    REVIEW_EXIT=$?
    
    echo "$REVIEW_OUTPUT"
    echo ""
    
    if [ $REVIEW_EXIT -ne 0 ]; then
        echo -e "${RED}❌ AI review found issues.${NC}"
        echo ""
        read -p "Push anyway? (y/N): " -n 1 -r
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Push aborted."
            exit 1
        fi
        echo -e "${YELLOW}⚠️  Pushing despite review issues.${NC}"
    else
        echo -e "${GREEN}✅ AI review passed.${NC}"
    fi
    
done

exit 0